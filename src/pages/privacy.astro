---
import Layout from "../layouts/Layout.astro";
const lastUpdated = "May 11, 2026";
---

<Layout title="Privacy Policy">
  <div class="bg-muted min-h-screen pb-16">
    <div class="bg-card border-b border-border py-8 md:py-12 relative overflow-hidden">
      <div class="absolute -top-1/2 -right-[10%] w-3/5 h-[200%] bg-radial-[circle] from-primary/5 to-transparent z-0"></div>
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 relative z-1">
        <h1 class="text-2xl md:text-4xl font-extrabold text-foreground tracking-tight mb-1">Privacy Policy</h1>
        <p class="text-sm text-muted-foreground">Last updated: {lastUpdated}</p>
      </div>
    </div>

    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 pt-10 flex flex-col gap-6">

      {[
        {
          title: "1. Information We Collect",
          body: "We collect information you provide directly when you create an account, such as your name, FSC email address, and profile details. We also collect information about your activity on the platform, including listings you create, messages you send, items you save, and transactions you complete."
        },
        {
          title: "2. How We Use Your Information",
          body: "We use your information to operate and improve the marketplace, facilitate communication between buyers and sellers, send important account notifications, enforce our terms of service, and ensure the safety and integrity of the platform."
        },
        {
          title: "3. Information Sharing",
          body: "We do not sell your personal information to third parties. Your profile information (name, listings, ratings) is visible to other verified FSC students on the platform. Your contact details and messages are only shared with users you choose to interact with."
        },
        {
          title: "4. Data Security",
          body: "We use industry-standard security measures, including encrypted connections (HTTPS) and secure data storage through Supabase, to protect your information. However, no method of transmission over the internet is 100% secure, and we cannot guarantee absolute security."
        },
        {
          title: "5. Data Retention",
          body: "We retain your account information for as long as your account is active. If you delete your account, we will remove your personal data within 30 days, except where retention is required by law or for legitimate business purposes such as dispute resolution."
        },
        {
          title: "6. Cookies",
          body: "We use cookies and similar technologies to maintain your session, remember your preferences (such as dark mode), and understand how users interact with the platform. You can disable cookies in your browser settings, though some features may not function properly."
        },
        {
          title: "7. Your Rights",
          body: "You have the right to access, correct, or delete your personal information at any time. You can update most information directly in your profile settings. To request account deletion or a copy of your data, contact us at marketplace@farmingdale.edu."
        },
        {
          title: "8. Changes to This Policy",
          body: "We may update this Privacy Policy from time to time. We will notify you of significant changes via email or a notice on the platform. Continued use of the marketplace after changes constitutes acceptance of the updated policy."
        },
        {
          title: "9. Contact",
          body: "If you have questions or concerns about this Privacy Policy, please contact us at marketplace@farmingdale.edu or through our Contact page."
        },
      ].map((section) => (
        <div class="bg-card border border-border rounded-xl p-5">
          <h2 class="text-sm font-extrabold text-foreground mb-2">{section.title}</h2>
          <p class="text-sm text-muted-foreground leading-relaxed">{section.body}</p>
        </div>
      ))}

    </div>
  </div>
</Layout>
