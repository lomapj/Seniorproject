---
import Layout from "../layouts/Layout.astro";
import { Card, CardContent } from "@/components/starwind/card";
import Button from "@/components/starwind/button/Button.astro";
import Badge from "@/components/starwind/badge/Badge.astro";
import { Avatar, AvatarFallback } from "@/components/starwind/avatar";
import { Breadcrumb, BreadcrumbItem, BreadcrumbLink, BreadcrumbList, BreadcrumbPage, BreadcrumbSeparator } from "@/components/starwind/breadcrumb";
import { Dialog, DialogTrigger, DialogContent, DialogHeader, DialogTitle, DialogDescription, DialogFooter, DialogClose } from "@/components/starwind/dialog";
import { NativeSelect, NativeSelectOption } from "@/components/starwind/native-select";
import Textarea from "@/components/starwind/textarea/Textarea.astro";
---

<Layout title="Item Detail">
  <div class="bg-muted min-h-screen pb-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 pt-6">
      <!-- Breadcrumb -->
      <Breadcrumb class="mb-6">
        <BreadcrumbList class="text-sm">
          <BreadcrumbItem>
            <BreadcrumbLink href="/marketplace">Marketplace</BreadcrumbLink>
          </BreadcrumbItem>
          <BreadcrumbSeparator />
          <BreadcrumbItem>
            <BreadcrumbLink href="/marketplace">Books</BreadcrumbLink>
          </BreadcrumbItem>
          <BreadcrumbSeparator />
          <BreadcrumbItem>
            <BreadcrumbPage class="font-bold">Biology Textbook</BreadcrumbPage>
          </BreadcrumbItem>
        </BreadcrumbList>
      </Breadcrumb>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        <!-- Left: Gallery -->
        <div class="flex flex-col gap-4">
          <div class="aspect-4/3 rounded-xl flex items-center justify-center shadow-xl border border-border" style="background: linear-gradient(135deg,#2d6a4f,#52b788)">
            <span class="text-[8rem] drop-shadow-lg">📗</span>
          </div>
          <div class="flex gap-3">
            {[1, 2, 3, 4].map((i) => (
              <button type="button" class={`thumb-btn flex-1 aspect-square rounded-lg flex items-center justify-center text-2xl transition-all opacity-60 hover:opacity-100 ${i === 1 ? "border-2 border-primary opacity-100 shadow-sm" : "border-2 border-transparent"}`} style="background: linear-gradient(135deg,#2d6a4f,#52b788)">
                <span>📗</span>
              </button>
            ))}
          </div>
        </div>

        <!-- Right: Content -->
        <div class="flex flex-col gap-5">
          <div class="flex items-center justify-between">
            <div class="flex gap-2">
              <Badge variant="outline" size="sm">Books</Badge>
              <Badge variant="ghost" size="sm" class="text-primary bg-primary/10">Like New</Badge>
            </div>
            <button type="button" class="w-11 h-11 rounded-full border border-border bg-card flex items-center justify-center text-muted-foreground hover:border-error hover:text-error transition-colors" id="favBtn" aria-label="Save listing">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
              </svg>
            </button>
          </div>

          <h1 class="text-3xl lg:text-4xl font-extrabold text-foreground tracking-tight">Biology Textbook</h1>

          <div class="flex items-center gap-4">
            <span class="text-3xl font-extrabold text-primary">$45</span>
            <Badge variant="success" size="sm">Available</Badge>
          </div>

          <Card size="sm">
            <CardContent class="grid grid-cols-3 gap-4">
              <div class="flex flex-col gap-0.5">
                <span class="text-xs font-semibold text-muted-foreground uppercase">Condition</span>
                <span class="text-sm font-bold text-foreground">Like New</span>
              </div>
              <div class="flex flex-col gap-0.5">
                <span class="text-xs font-semibold text-muted-foreground uppercase">Posted</span>
                <span class="text-sm font-bold text-foreground">2 days ago</span>
              </div>
              <div class="flex flex-col gap-0.5">
                <span class="text-xs font-semibold text-muted-foreground uppercase">Location</span>
                <span class="text-sm font-bold text-foreground">Conklin Hall</span>
              </div>
            </CardContent>
          </Card>

          <div class="mt-2">
            <h2 class="text-base font-extrabold text-foreground mb-2">Description</h2>
            <p class="text-base text-muted-foreground leading-relaxed">
              Gently used Florida Biology textbook in excellent condition. This
              comprehensive biology textbook covers all major topics including
              cell biology, genetics, evolution, and ecology. Perfect for BIO
              101 or general biology courses.
            </p>
          </div>

          <!-- Seller Card -->
          <Card size="sm" class="shadow-md">
            <CardContent class="flex items-center justify-between gap-4">
              <div class="flex items-center gap-3">
                <Avatar size="lg" variant="primary" class="w-14 h-14 text-xl shadow-md"><AvatarFallback class="bg-primary text-primary-foreground font-extrabold">SJ</AvatarFallback></Avatar>
                <div class="flex flex-col gap-0.5">
                  <span class="text-base font-extrabold text-foreground">Sarah J.</span>
                  <div class="flex items-center gap-2">
                    <span class="text-amber-400 text-sm">★★★★★</span>
                    <span class="text-sm text-muted-foreground font-medium">4.5 (12 reviews)</span>
                  </div>
                </div>
              </div>
              <Button variant="outline" size="sm" href="/profile/sarah">View Profile</Button>
            </CardContent>
          </Card>

          <!-- Actions -->
          <div class="grid grid-cols-[1fr_auto] gap-3 mt-2">
            <Button variant="primary" href="/messages/new" class="gap-2 font-extrabold">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
              Message Seller
            </Button>
            <Dialog>
              <DialogTrigger class="inline-flex items-center justify-center border border-border text-muted-foreground hover:text-error hover:border-error gap-1.5 rounded-md px-4 py-2 text-sm font-medium transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path><line x1="4" y1="22" x2="4" y2="15"></line></svg>
                Report
              </DialogTrigger>
              <DialogContent class="max-w-120">
                <DialogHeader>
                  <DialogTitle>Report Listing</DialogTitle>
                  <DialogDescription>Help us keep our community safe. Why are you reporting this?</DialogDescription>
                </DialogHeader>
                <div class="space-y-4 py-4">
                  <div class="space-y-1.5">
                    <label class="text-sm font-semibold text-foreground">Reason</label>
                    <NativeSelect>
                      <NativeSelectOption>Inappropriate content</NativeSelectOption>
                      <NativeSelectOption>Suspected scam</NativeSelectOption>
                      <NativeSelectOption>Wrong category</NativeSelectOption>
                      <NativeSelectOption>Prohibited item</NativeSelectOption>
                      <NativeSelectOption>Other</NativeSelectOption>
                    </NativeSelect>
                  </div>
                  <div class="space-y-1.5">
                    <label class="text-sm font-semibold text-foreground">Details</label>
                    <Textarea placeholder="Additional information..." rows={3} />
                  </div>
                </div>
                <DialogFooter>
                  <DialogClose asChild>
                    <Button variant="secondary">Cancel</Button>
                  </DialogClose>
                  <Button variant="error">Submit Report</Button>
                </DialogFooter>
              </DialogContent>
            </Dialog>
          </div>
        </div>
      </div>
    </div>

  </div>
</Layout>

<script>
  const favBtn = document.getElementById("favBtn");
  const thumbs = document.querySelectorAll<HTMLButtonElement>(".thumb-btn");

  favBtn?.addEventListener("click", () => favBtn.classList.toggle("saved"));

  thumbs.forEach((thumb) => {
    thumb.addEventListener("click", () => {
      thumbs.forEach((t) => {
        t.classList.remove("border-primary", "opacity-100", "shadow-sm");
        t.classList.add("border-transparent", "opacity-60");
      });
      thumb.classList.add("border-primary", "opacity-100", "shadow-sm");
      thumb.classList.remove("border-transparent", "opacity-60");
    });
  });
</script>
