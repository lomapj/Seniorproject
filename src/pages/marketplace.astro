---
import Layout from "../layouts/Layout.astro";
import Button from "@/components/starwind/button/Button.astro";
import Badge from "@/components/starwind/badge/Badge.astro";
import { NativeSelect, NativeSelectOption } from "@/components/starwind/native-select";

const listings = [
  { id: 1, title: "Premium Headphones", price: 80, category: "Electronics", condition: "Like New", seller: "Sarah J.", rating: 4.5, reviews: 12, image: "/img/generated/headphones.png", gradient: "linear-gradient(135deg, #006153, #00a896)", status: "available" },
  { id: 2, title: "Calculus Textbook", price: 45, category: "Books", condition: "Good", seller: "Michael T.", rating: 4.8, reviews: 33, image: "/img/generated/textbook.png", gradient: "linear-gradient(135deg, #fce043, #fb7419)", status: "available" },
  { id: 3, title: "MacBook Pro M1", price: 950, category: "Electronics", condition: "Good", seller: "David K.", rating: 4.7, reviews: 19, gradient: "linear-gradient(135deg, #1e3c72, #2a5298)", icon: "💻", status: "available" },
  { id: 5, title: "Scientific Calculator", price: 22, category: "Electronics", condition: "Like New", seller: "Chris M.", rating: 5.0, reviews: 8, gradient: "linear-gradient(135deg,#e07a5f,#c1440e)", icon: "🔢", status: "available" },
  { id: 6, title: "Winter Jacket (L)", price: 40, category: "Clothing", condition: "Good", seller: "Aisha B.", rating: 4.4, reviews: 5, gradient: "linear-gradient(135deg,#457b9d,#1d3557)", icon: "🧥", status: "available" },
  { id: 7, title: "Chemistry Lab Manual", price: 18, category: "Books", condition: "Fair", seller: "Jake P.", rating: 3.9, reviews: 4, gradient: "linear-gradient(135deg,#606c38,#283618)", icon: "🧪", status: "available" },
  { id: 8, title: "Wireless Headphones", price: 65, category: "Electronics", condition: "Like New", seller: "Maria L.", rating: 4.6, reviews: 21, gradient: "linear-gradient(135deg,#6930c3,#48bfe3)", icon: "🎧", status: "available" },
  { id: 9, title: "Bookshelf", price: 55, category: "Furniture", condition: "Good", seller: "Omar S.", rating: 4.3, reviews: 6, gradient: "linear-gradient(135deg,#a0522d,#cd853f)", icon: "📚", status: "pending" },
  { id: 10, title: "Psychology Textbook", price: 30, category: "Books", condition: "Good", seller: "Lily C.", rating: 4.1, reviews: 9, gradient: "linear-gradient(135deg,#c77dff,#7b2d8b)", icon: "🧠", status: "available" },
  { id: 11, title: "USB-C Hub", price: 25, category: "Electronics", condition: "Like New", seller: "Tom W.", rating: 4.9, reviews: 14, gradient: "linear-gradient(135deg,#4cc9f0,#4361ee)", icon: "🔌", status: "available" },
  { id: 12, title: "Backpack", price: 28, category: "Misc", condition: "Good", seller: "Nadia F.", rating: 4.5, reviews: 11, gradient: "linear-gradient(135deg,#ef476f,#f78c6b)", icon: "🎒", status: "available" },
];
---

<Layout title="Marketplace">
  <div class="bg-muted pb-16">
    <!-- Hero -->
    <div class="bg-card border-b border-border py-8 md:py-12 relative overflow-hidden">
      <div class="absolute -top-1/2 -right-[10%] w-3/5 h-[200%] bg-radial-[circle] from-primary/5 to-transparent z-0"></div>
      <div class="mx-auto max-w-7xl px-6 lg:px-8 relative z-1">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
          <div>
            <h1 class="text-3xl md:text-4xl font-extrabold text-foreground tracking-tight mb-1">Campus Marketplace</h1>
            <p class="text-base text-muted-foreground">Buy and sell items with your fellow Farmingdale students</p>
          </div>
          <Button variant="primary" href="/post" class="shadow-lg shadow-primary/20 gap-2">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Sell An Item
          </Button>
        </div>
      </div>
    </div>

    <!-- Category Filter Bar -->
    <div class="bg-card border-b border-border sticky top-18 z-50 shadow-sm">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-stretch md:items-center justify-between gap-4 py-3">
          <div class="flex gap-2 overflow-x-auto scrollbar-hide pb-0.5" id="catChips">
            {["All", "Books", "Electronics", "Furniture", "Clothing", "Misc"].map((cat, i) => (
              <button class={`cat-chip whitespace-nowrap px-4 py-2 rounded-full border text-sm font-semibold transition-all ${i === 0 ? "bg-primary border-primary text-primary-foreground shadow-sm" : "bg-card border-border text-muted-foreground hover:border-primary hover:text-primary"}`} data-cat={cat}>
                {cat}
              </button>
            ))}
          </div>
          <div class="flex items-center gap-3 shrink-0">
            <span class="text-sm font-semibold text-muted-foreground">Sort by</span>
            <NativeSelect size="sm" class="min-w-44">
              <NativeSelectOption>Newest First</NativeSelectOption>
              <NativeSelectOption>Price: Low to High</NativeSelectOption>
              <NativeSelectOption>Price: High to Low</NativeSelectOption>
              <NativeSelectOption>Top Rated</NativeSelectOption>
            </NativeSelect>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="mx-auto max-w-7xl px-6 lg:px-8 pt-6">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
        <h2 class="text-lg text-muted-foreground font-medium">
          <strong class="font-extrabold text-primary">{listings.length}</strong> Results Found
        </h2>
        <div class="flex items-center gap-3 bg-card p-2 rounded-lg border border-border">
          <div class="relative flex items-center">
            <span class="absolute left-3 text-sm text-muted-foreground font-semibold">$</span>
            <input type="number" class="w-22 pl-7 pr-2 py-1.5 border border-border rounded-md text-sm bg-muted focus:bg-card focus:border-primary focus:outline-none" placeholder="Min" />
          </div>
          <span class="text-muted-foreground">—</span>
          <div class="relative flex items-center">
            <span class="absolute left-3 text-sm text-muted-foreground font-semibold">$</span>
            <input type="number" class="w-22 pl-7 pr-2 py-1.5 border border-border rounded-md text-sm bg-muted focus:bg-card focus:border-primary focus:outline-none" placeholder="Max" />
          </div>
          <button class="px-3 py-1.5 bg-primary/10 text-primary rounded-md text-sm font-bold hover:bg-primary hover:text-primary-foreground transition-colors btn-filter-apply">Apply</button>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="listingGrid">
        {listings.map((item) => (
          <a href="/item" class="listing-card group bg-card rounded-xl border border-border overflow-hidden no-underline text-inherit flex flex-col shadow-sm hover:-translate-y-2 hover:shadow-xl hover:border-primary/20 transition-all duration-300" data-category={item.category} data-price={item.price}>
            <div class="h-55 relative flex items-center justify-center overflow-hidden" style={`background: ${item.gradient}`}>
              {item.image ? (
                <img src={item.image} alt={item.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
              ) : (
                <span class="text-5xl">{item.icon}</span>
              )}
              <button type="button" class="card-fav-btn absolute top-3 right-3 w-10 h-10 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center text-muted-foreground hover:text-error z-10 border-0" aria-label="Save listing" onclick="event.preventDefault(); this.classList.toggle('saved')">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                </svg>
              </button>
              {item.status !== "available" && (
                <div class={`absolute inset-0 bg-black/40 flex items-center justify-center z-10`}>
                  <span class="px-4 py-1.5 rounded-full font-extrabold uppercase tracking-widest text-sm text-white border-2 border-white">{item.status}</span>
                </div>
              )}
            </div>
            <div class="p-4 flex-1 flex flex-col gap-2">
              <div class="flex items-center justify-between">
                <Badge variant="ghost" size="sm" class="text-primary bg-primary/10">{item.condition}</Badge>
                <span class="flex items-center gap-1 text-sm font-bold text-muted-foreground">
                  {item.rating}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" class="text-amber-400"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
                </span>
              </div>
              <h3 class="text-base font-bold text-foreground leading-tight line-clamp-2">{item.title}</h3>
              <div class="flex items-center justify-between mt-auto pt-3 border-t border-border">
                <span class="text-xl font-extrabold text-primary">${item.price}</span>
                <span class="text-sm font-semibold text-muted-foreground">{item.seller.split(" ")[0]}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>

<style>
  .card-fav-btn.saved { color: var(--color-red-500); }
  .card-fav-btn.saved svg { fill: var(--color-red-500); stroke: var(--color-red-500); }
  .cat-chip.active { background: var(--primary); border-color: var(--primary); color: var(--primary-foreground); }
</style>

<script>
  const catChips = document.querySelectorAll(".cat-chip");
  const listingGrid = document.getElementById("listingGrid");
  const listingCards = document.querySelectorAll(".listing-card");
  const priceMin = document.querySelector<HTMLInputElement>("input[placeholder='Min']");
  const priceMax = document.querySelector<HTMLInputElement>("input[placeholder='Max']");
  const applyBtn = document.querySelector(".btn-filter-apply");

  let currentCat = "All";

  function filterListings() {
    const min = parseFloat(priceMin?.value || "0");
    const max = parseFloat(priceMax?.value || "Infinity") || Infinity;
    const params = new URLSearchParams(window.location.search);
    const query = (params.get("q") || params.get("search"))?.toLowerCase() || "";
    const savedOnly = params.get("saved") === "true";
    const savedIds = new Set(JSON.parse(localStorage.getItem("fsc_marketplace_saved") || "[]").map((id: any) => id.toString()));

    listingCards.forEach((c) => {
      const card = c as HTMLElement;
      const cardId = card.getAttribute("data-id") || "";
      const cardCat = card.getAttribute("data-category");
      const cardPrice = parseFloat(card.getAttribute("data-price") || "0");
      const cardTitle = card.querySelector("h3")?.textContent?.toLowerCase() || "";

      const catMatch = currentCat === "All" || cardCat === currentCat;
      const priceMatch = cardPrice >= min && cardPrice <= max;
      const searchMatch = !query || cardTitle.includes(query);
      const savedMatch = !savedOnly || savedIds.has(cardId);

      if (catMatch && priceMatch && searchMatch && savedMatch) {
        card.style.display = "flex";
        setTimeout(() => card.classList.add("fade-in-visible"), 10);
      } else {
        card.style.display = "none";
        card.classList.remove("fade-in-visible");
      }
    });

    const visibleCount = Array.from(listingCards).filter((c) => (c as HTMLElement).style.display !== "none").length;
    const countEl = document.querySelector(".results-count strong, h2 strong");
    if (countEl) countEl.textContent = visibleCount.toString();
  }

  catChips.forEach((chip) => {
    chip.addEventListener("click", () => {
      catChips.forEach((c) => {
        c.classList.remove("active", "bg-primary", "border-primary", "text-primary-foreground", "shadow-sm");
        c.classList.add("bg-card", "border-border", "text-muted-foreground");
      });
      chip.classList.add("active", "bg-primary", "border-primary", "text-primary-foreground", "shadow-sm");
      chip.classList.remove("bg-card", "border-border", "text-muted-foreground");
      currentCat = chip.getAttribute("data-cat") || "All";
      filterListings();
    });
  });

  applyBtn?.addEventListener("click", filterListings);
  filterListings();

  const observerOptions = { threshold: 0.1, rootMargin: "0px 0px -50px 0px" };
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add("fade-in-visible");
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  listingCards.forEach((card) => {
    card.classList.add("fade-in-shimmer");
    observer.observe(card);
  });

  window.addEventListener("saved-changed", filterListings);
</script>

<style is:global>
  .fade-in-shimmer { opacity: 0; transform: translateY(20px); transition: opacity 0.6s cubic-bezier(0.23, 1, 0.32, 1), transform 0.6s cubic-bezier(0.23, 1, 0.32, 1); }
  .fade-in-visible { opacity: 1; transform: translateY(0); }
</style>
