---
import Layout from "../layouts/Layout.astro";
import Button from "@/components/starwind/button/Button.astro";
import { NativeSelect, NativeSelectOption } from "@/components/starwind/native-select";
---

<Layout title="Marketplace">
  <div class="bg-muted pb-16">
    <div class="bg-card border-b border-border py-5 md:py-12 relative overflow-hidden">
      <div class="absolute -top-1/2 -right-[10%] w-3/5 h-[200%] bg-radial-[circle] from-primary/5 to-transparent z-0"></div>
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-1">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
          <div class="min-w-0">
            <h1 class="text-xl sm:text-2xl md:text-4xl font-extrabold text-foreground tracking-tight mb-1 truncate">Campus Marketplace</h1>
            <p class="text-base text-muted-foreground">Buy and sell items with your fellow Farmingdale students</p>
          </div>
          <Button variant="primary" href="/post" class="shadow-lg shadow-primary/20 gap-2 shrink-0 whitespace-nowrap px-3 sm:px-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Sell An Item
          </Button>
        </div>
      </div>
    </div>
    
    <div class="bg-card border-b border-border sticky top-18 z-50 shadow-sm">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between gap-4 py-3">
          <div class="flex gap-2 overflow-x-auto scrollbar-hide pb-0.5" id="catChips">
            {["All", "Books", "Electronics", "Furniture", "Clothing", "Misc"].map((cat, i) => (
              <button class={`cat-chip whitespace-nowrap px-4 py-2 rounded-full border text-sm font-semibold transition-all ${i === 0 ? "active bg-primary border-primary text-primary-foreground shadow-sm" : "bg-card border-border text-muted-foreground hover:border-primary hover:text-primary"}`} data-cat={cat}>
                {cat}
              </button>
            ))}
          </div>
          <button type="button" id="advancedSearchToggle" class="relative inline-flex items-center gap-2 px-3 sm:px-4 py-2 rounded-full border border-border bg-card text-sm font-semibold text-muted-foreground hover:border-primary hover:text-primary transition-all shrink-0 w-10 h-10 sm:w-auto sm:h-auto justify-center">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
            <span class="hidden md:inline">Filters</span>
            <span id="activeFilterCount" class="hidden absolute -top-1.5 -right-1.5 md:hidden min-w-5 h-5 rounded-full bg-primary text-primary-foreground text-xs font-bold items-center justify-center">0</span>
            <span id="activeFilterCountDesktop" class="hidden min-w-5 h-5 rounded-full bg-primary text-primary-foreground text-xs font-bold items-center justify-center">0</span>
          </button>
        </div>
      </div>
    </div>
    
    <div id="advancedSearchPanel" class="hidden bg-card border-b border-border shadow-inner">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-5">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-base font-bold text-foreground flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg>
            Advanced Search
          </h3>
          <div class="flex items-center gap-2">
            <button type="button" id="clearAllFilters" class="text-sm font-semibold text-muted-foreground hover:text-error transition-colors">Clear All</button>
            <button type="button" id="closeAdvancedSearch" class="w-8 h-8 rounded-full flex items-center justify-center text-muted-foreground hover:bg-muted hover:text-foreground transition-all">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
          </div>
        </div>
        <div class="flex flex-col gap-1.5 mb-4">
          <label class="text-xs font-bold text-muted-foreground uppercase tracking-wide">Listing Type</label>
          <div class="flex gap-2 flex-wrap">
            <button type="button" class="listing-type-chip px-3 py-1.5 rounded-full border text-xs font-semibold transition-all bg-teal-500/10 border-teal-300 text-teal-700 hover:bg-teal-500/20" data-type="Free">🎁 Free</button>
            <button type="button" class="listing-type-chip px-3 py-1.5 rounded-full border text-xs font-semibold transition-all bg-amber-500/10 border-amber-300 text-amber-700 hover:bg-amber-500/20" data-type="Auctions">⏱ Auctions</button>
            <button type="button" class="listing-type-chip px-3 py-1.5 rounded-full border text-xs font-semibold transition-all bg-orange-500/10 border-orange-300 text-orange-700 hover:bg-orange-500/20" data-type="On Sale">🏷️ On Sale</button>
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4">
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-bold text-muted-foreground uppercase tracking-wider">Sort By</label>
            <div class="flex flex-wrap gap-1.5" id="sortChips">
              {[
                { value: "newest", label: "Newest" },
                { value: "price_asc", label: "$ Low→High" },
                { value: "price_desc", label: "$ High→Low" },
                { value: "rating_desc", label: "Top Rated" },
                { value: "views_desc", label: "Most Viewed" },
              ].map((opt, i) => (
                <button type="button" class={`sort-chip px-2.5 py-1 rounded-full border text-xs font-semibold transition-all ${i === 0 ? "bg-primary/10 border-primary/30 text-primary" : "bg-muted border-border text-muted-foreground hover:border-primary/30 hover:text-primary"}`} data-sort={opt.value}>{opt.label}</button>
              ))}
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-bold text-muted-foreground uppercase tracking-wider">Date Posted</label>
            <div class="flex flex-wrap gap-1.5" id="dateChips">
              {[
                { value: "any", label: "Any" },
                { value: "today", label: "Today" },
                { value: "3days", label: "3 Days" },
                { value: "week", label: "Week" },
                { value: "month", label: "Month" },
                { value: "3months", label: "3 Months" },
              ].map((opt, i) => (
                <button type="button" class={`date-chip px-2.5 py-1 rounded-full border text-xs font-semibold transition-all ${i === 0 ? "bg-primary/10 border-primary/30 text-primary" : "bg-muted border-border text-muted-foreground hover:border-primary/30 hover:text-primary"}`} data-date={opt.value}>{opt.label}</button>
              ))}
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-bold text-muted-foreground uppercase tracking-wider">Price Range</label>
            <div class="flex items-center gap-1.5">
              <div class="relative flex items-center flex-1">
                <span class="absolute left-2.5 text-xs text-muted-foreground font-bold">$</span>
                <input type="number" id="priceMin" class="w-full pl-6 pr-2 py-2 border border-border rounded-xl text-sm bg-muted focus:bg-card focus:border-primary focus:outline-none" placeholder="Min" min="0" />
              </div>
              <span class="text-muted-foreground text-xs font-bold shrink-0">&ndash;</span>
              <div class="relative flex items-center flex-1">
                <span class="absolute left-2.5 text-xs text-muted-foreground font-bold">$</span>
                <input type="number" id="priceMax" class="w-full pl-6 pr-2 py-2 border border-border rounded-xl text-sm bg-muted focus:bg-card focus:border-primary focus:outline-none" placeholder="Max" min="0" />
              </div>
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-bold text-muted-foreground uppercase tracking-wider">Min Views</label>
            <div class="relative flex items-center">
              <svg class="absolute left-2.5 text-muted-foreground" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <input type="number" id="minViews" class="w-full pl-8 pr-2 py-2 border border-border rounded-xl text-sm bg-muted focus:bg-card focus:border-primary focus:outline-none" placeholder="e.g. 10" min="0" />
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 mt-3">
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-bold text-muted-foreground uppercase tracking-wider">Condition</label>
            <div class="flex flex-wrap gap-1.5" id="conditionChips">
              {["Any", "New", "Like New", "Good", "Fair", "Poor"].map((cond, i) => (
                <button type="button" class={`cond-chip px-2.5 py-1 rounded-full border text-xs font-semibold transition-all ${i === 0 ? "bg-primary/10 border-primary/30 text-primary" : "bg-muted border-border text-muted-foreground hover:border-primary/30 hover:text-primary"}`} data-condition={cond}>{cond}</button>
              ))}
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-bold text-muted-foreground uppercase tracking-wider">Seller Rating</label>
            <div class="flex flex-wrap gap-1.5" id="ratingFilter">
              {[{ value: "any", label: "Any" }, { value: "4", label: "4★+" }, { value: "3", label: "3★+" }, { value: "2", label: "2★+" }].map((opt, i) => (
                <button type="button" class={`rating-chip px-2.5 py-1 rounded-full border text-xs font-semibold transition-all ${i === 0 ? "bg-primary/10 border-primary/30 text-primary" : "bg-muted border-border text-muted-foreground hover:border-primary/30 hover:text-primary"}`} data-rating={opt.value}>{opt.label}</button>
              ))}
            </div>
          </div>
        </div>

        <div class="flex items-center justify-between mt-3 pt-3 border-t border-border gap-4">
          <div class="flex items-center gap-4 flex-wrap">
            <label class="flex items-center gap-2.5 cursor-pointer group">
              <div class="relative shrink-0">
                <input type="checkbox" id="hideOwnListings" class="sr-only peer" />
                <div class="w-9 h-5 rounded-full bg-muted border border-border peer-checked:bg-primary peer-checked:border-primary transition-all"></div>
                <div class="absolute left-0.5 top-0.5 w-4 h-4 rounded-full bg-white shadow-sm transition-transform peer-checked:translate-x-4"></div>
              </div>
              <span class="text-xs font-semibold text-muted-foreground group-hover:text-foreground transition-colors whitespace-nowrap">Hide mine</span>
            </label>
            <label class="flex items-center gap-2.5 cursor-pointer group">
              <div class="relative shrink-0">
                <input type="checkbox" id="showOnlyOwn" class="sr-only peer" />
                <div class="w-9 h-5 rounded-full bg-muted border border-border peer-checked:bg-primary peer-checked:border-primary transition-all"></div>
                <div class="absolute left-0.5 top-0.5 w-4 h-4 rounded-full bg-white shadow-sm transition-transform peer-checked:translate-x-4"></div>
              </div>
              <span class="text-xs font-semibold text-muted-foreground group-hover:text-foreground transition-colors whitespace-nowrap">Only mine</span>
            </label>
          </div>
          <button type="button" id="applyFiltersBtn" class="shrink-0 px-5 py-2 bg-primary text-primary-foreground rounded-full text-sm font-bold hover:bg-primary/90 transition-colors shadow-sm shadow-primary/20">Apply Filters</button>
        </div>
      </div>
    </div>
    
    <div id="trendingSection" class="hidden mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-6">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
          <span class="text-xl">🔥</span>
          <h2 class="text-lg font-extrabold text-foreground">Trending</h2>
          <span class="text-xs font-semibold text-muted-foreground">Most viewed today</span>
        </div>
        <button type="button" id="hideTrendingBtn" class="w-7 h-7 rounded-full flex items-center justify-center text-muted-foreground hover:bg-muted hover:text-foreground transition-all" aria-label="Toggle trending">
          <svg id="trendingChevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300"><polyline points="18 15 12 9 6 15"></polyline></svg>
        </button>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="trendingGrid"></div>
      <div class="border-b border-border mt-6"></div>
    </div>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-6">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 gap-4">
        <h2 class="text-lg text-muted-foreground font-medium">
          <strong class="font-extrabold text-primary" id="resultsCount">0</strong> Results Found
        </h2>
        <div class="flex items-center gap-2 flex-wrap" id="activeFiltersBar"></div>
      </div>
      <div id="loadingSkeleton" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {Array.from({ length: 8 }).map(() => (
          <div class="bg-card rounded-xl border border-border overflow-hidden flex flex-col shadow-sm animate-pulse">
            <div class="h-55 bg-muted"></div>
            <div class="p-4 flex-1 flex flex-col gap-3">
              <div class="flex justify-between"><div class="h-5 w-20 bg-muted rounded"></div><div class="h-5 w-10 bg-muted rounded"></div></div>
              <div class="h-5 w-3/4 bg-muted rounded"></div>
              <div class="flex justify-between mt-auto pt-3 border-t border-border"><div class="h-6 w-16 bg-muted rounded"></div><div class="h-5 w-14 bg-muted rounded"></div></div>
            </div>
          </div>
        ))}
      </div>
      <div id="emptyState" class="hidden text-center py-20">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto text-muted-foreground mb-4"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path></svg>
        <h3 class="text-xl font-bold text-foreground mb-2">No listings found</h3>
        <p class="text-muted-foreground">Try adjusting your filters or search terms.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 hidden" id="listingGrid"></div>
    </div>
  </div>
</Layout>

<style>
  .card-fav-btn.saved { color: var(--color-red-500); }
  .card-fav-btn.saved svg { fill: var(--color-red-500); stroke: var(--color-red-500); }
  .cat-chip.active { background: var(--primary); border-color: var(--primary); color: var(--primary-foreground); }
</style>

<script>
  import { fetchListings, fetchSellerRating, fetchBids, type Listing } from "../lib/api";
  import { supabase } from "@/lib/supabase.ts";
  import { fetchSavedListingIds, toggleSaveListing } from "@/lib/api.ts";

  const CATEGORY_GRADIENTS: Record<string, string> = {
    Books: "linear-gradient(135deg,#2d6a4f,#52b788)",
    Electronics: "linear-gradient(135deg,#1e3c72,#2a5298)",
    Furniture: "linear-gradient(135deg,#a0522d,#cd853f)",
    Clothing: "linear-gradient(135deg,#457b9d,#1d3557)",
    Misc: "linear-gradient(135deg,#ef476f,#f78c6b)",
  };

  const CATEGORY_ICONS: Record<string, string> = {
    Books: "\u{1F4D7}", Electronics: "\u{1F4BB}", Furniture: "\u{1FA91}", Clothing: "\u{1F9E5}", Misc: "\u{1F4E6}",
  };

  const listingGrid = document.getElementById("listingGrid")!;
  const loadingSkeleton = document.getElementById("loadingSkeleton")!;
  const emptyState = document.getElementById("emptyState")!;
  const resultsCount = document.getElementById("resultsCount")!;
  const catChips = document.querySelectorAll(".cat-chip");
  const sortChips = document.querySelectorAll<HTMLElement>(".sort-chip");
  const dateChips = document.querySelectorAll<HTMLElement>(".date-chip");
  const priceMin = document.getElementById("priceMin") as HTMLInputElement;
  const priceMax = document.getElementById("priceMax") as HTMLInputElement;
  const advancedSearchToggle = document.getElementById("advancedSearchToggle")!;
  const advancedSearchPanel = document.getElementById("advancedSearchPanel")!;
  const closeAdvancedSearch = document.getElementById("closeAdvancedSearch")!;
  const clearAllFilters = document.getElementById("clearAllFilters")!;
  const applyFiltersBtn = document.getElementById("applyFiltersBtn")!;
  const activeFilterCount = document.getElementById("activeFilterCount")!;
  const activeFiltersBar = document.getElementById("activeFiltersBar")!;
  const condChips = document.querySelectorAll(".cond-chip");
  const ratingChips = document.querySelectorAll<HTMLElement>(".rating-chip");
  const hideOwnListings = document.getElementById("hideOwnListings") as HTMLInputElement;
  const showOnlyOwn = document.getElementById("showOnlyOwn") as HTMLInputElement;
  const minViews = document.getElementById("minViews") as HTMLInputElement;

  let currentCat = "All";
  let currentListingType = "";
  let allListings: Listing[] = [];
  let selectedCondition = "Any";
  let selectedRating = "any";
  let selectedSort = "newest";
  let selectedDate = "any";
  let sellerRatingsCache: Record<string, { average: number; count: number }> = {};

  const initParams = new URLSearchParams(window.location.search);
  const urlCat = initParams.get("cat");
  if (urlCat) {
    if (urlCat === "Free" || urlCat === "Auctions" || urlCat === "On Sale") {
      currentListingType = urlCat;
    } else {
      currentCat = urlCat;
      catChips.forEach((chip) => {
        const chipCat = chip.getAttribute("data-cat");
        if (chipCat === urlCat) { chip.classList.add("active", "bg-primary", "border-primary", "text-primary-foreground", "shadow-sm"); chip.classList.remove("bg-card", "border-border", "text-muted-foreground"); }
        else { chip.classList.remove("active", "bg-primary", "border-primary", "text-primary-foreground", "shadow-sm"); chip.classList.add("bg-card", "border-border", "text-muted-foreground"); }
      });
    }
  }

  advancedSearchToggle.addEventListener("click", () => {
    const isHidden = advancedSearchPanel.classList.contains("hidden");
    if (isHidden) { advancedSearchPanel.classList.remove("hidden"); advancedSearchToggle.classList.add("border-primary", "text-primary", "bg-primary/5"); advancedSearchToggle.classList.remove("border-border", "text-muted-foreground", "bg-card"); }
    else { advancedSearchPanel.classList.add("hidden"); if (countActiveFilters() === 0) { advancedSearchToggle.classList.remove("border-primary", "text-primary", "bg-primary/5"); advancedSearchToggle.classList.add("border-border", "text-muted-foreground", "bg-card"); } }
  });

  closeAdvancedSearch.addEventListener("click", () => {
    advancedSearchPanel.classList.add("hidden");
    if (countActiveFilters() === 0) { advancedSearchToggle.classList.remove("border-primary", "text-primary", "bg-primary/5"); advancedSearchToggle.classList.add("border-border", "text-muted-foreground", "bg-card"); }
  });

  condChips.forEach((chip) => {
    chip.addEventListener("click", () => {
      condChips.forEach((c) => { c.classList.remove("bg-primary/10", "border-primary/30", "text-primary"); c.classList.add("bg-muted", "border-border", "text-muted-foreground"); });
      chip.classList.add("bg-primary/10", "border-primary/30", "text-primary");
      chip.classList.remove("bg-muted", "border-border", "text-muted-foreground");
      selectedCondition = chip.getAttribute("data-condition") || "Any";
    });
  });

  function activateChip(chips: NodeListOf<HTMLElement>, active: HTMLElement) {
    chips.forEach((c) => { c.classList.remove("bg-primary/10", "border-primary/30", "text-primary"); c.classList.add("bg-muted", "border-border", "text-muted-foreground"); });
    active.classList.add("bg-primary/10", "border-primary/30", "text-primary");
    active.classList.remove("bg-muted", "border-border", "text-muted-foreground");
  }

  sortChips.forEach((chip) => {
    chip.addEventListener("click", () => {
      activateChip(sortChips, chip);
      selectedSort = chip.getAttribute("data-sort") || "newest";
    });
  });

  dateChips.forEach((chip) => {
    chip.addEventListener("click", () => {
      activateChip(dateChips, chip);
      selectedDate = chip.getAttribute("data-date") || "any";
    });
  });

  ratingChips.forEach((chip) => {
    chip.addEventListener("click", () => {
      activateChip(ratingChips, chip);
      selectedRating = chip.getAttribute("data-rating") || "any";
    });
  });

  hideOwnListings.addEventListener("change", () => { if (hideOwnListings.checked) showOnlyOwn.checked = false; });
  showOnlyOwn.addEventListener("change", () => { if (showOnlyOwn.checked) hideOwnListings.checked = false; });

  function countActiveFilters(): number {
    let count = 0;
    if (selectedSort !== "newest") count++;
    if (priceMin.value && parseFloat(priceMin.value) > 0) count++;
    if (priceMax.value && parseFloat(priceMax.value) > 0) count++;
    if (selectedCondition !== "Any") count++;
    if (selectedDate !== "any") count++;
    if (selectedRating !== "any") count++;
    if (hideOwnListings.checked) count++;
    if (showOnlyOwn.checked) count++;
    if (minViews.value && parseInt(minViews.value) > 0) count++;
    if (currentListingType) count++;
    return count;
  }

  const activeFilterCountDesktop = document.getElementById("activeFilterCountDesktop")!;

  function updateFilterBadge() {
    const count = countActiveFilters();
    const isMobile = window.innerWidth < 768;
    if (count > 0) {
      const badge = isMobile ? activeFilterCount : activeFilterCountDesktop;
      const other = isMobile ? activeFilterCountDesktop : activeFilterCount;
      badge.classList.remove("hidden"); badge.classList.add("flex"); badge.textContent = count.toString();
      other.classList.add("hidden"); other.classList.remove("flex");
      advancedSearchToggle.classList.add("border-primary", "text-primary", "bg-primary/5");
      advancedSearchToggle.classList.remove("border-border", "text-muted-foreground", "bg-card");
    } else {
      activeFilterCount.classList.add("hidden"); activeFilterCount.classList.remove("flex");
      activeFilterCountDesktop.classList.add("hidden"); activeFilterCountDesktop.classList.remove("flex");
      if (advancedSearchPanel.classList.contains("hidden")) {
        advancedSearchToggle.classList.remove("border-primary", "text-primary", "bg-primary/5");
        advancedSearchToggle.classList.add("border-border", "text-muted-foreground", "bg-card");
      }
    }
  }

  function renderActiveFilterPills() {
    const pills: string[] = [];
    if (selectedCondition !== "Any") pills.push(makeFilterPill("Condition: " + selectedCondition, "condition"));
    const dateLabels: Record<string, string> = { today: "Today", "3days": "3 Days", week: "Week", month: "Month", "3months": "3 Months" };
    if (selectedDate !== "any") pills.push(makeFilterPill(dateLabels[selectedDate] || selectedDate, "date"));
    const minVal = priceMin.value ? parseFloat(priceMin.value) : 0;
    const maxVal = priceMax.value ? parseFloat(priceMax.value) : 0;
    if (minVal > 0 || maxVal > 0) {
      const priceLabel = minVal > 0 && maxVal > 0 ? `$${minVal} - $${maxVal}` : minVal > 0 ? `$${minVal}+` : `Up to $${maxVal}`;
      pills.push(makeFilterPill(priceLabel, "price"));
    }
    if (selectedRating !== "any") pills.push(makeFilterPill(selectedRating + "★ & Up", "rating"));
    if (currentListingType) pills.push(makeFilterPill(currentListingType, "listingType"));
    if (minViews.value && parseInt(minViews.value) > 0) pills.push(makeFilterPill(`${minViews.value}+ views`, "minViews"));
    if (hideOwnListings.checked) pills.push(makeFilterPill("Hiding my listings", "hideOwn"));
    if (showOnlyOwn.checked) pills.push(makeFilterPill("Only my listings", "showOwn"));
    const sortLabels: Record<string, string> = { price_asc: "$ Low→High", price_desc: "$ High→Low", rating_desc: "Top Rated", views_desc: "Most Viewed" };
    if (selectedSort !== "newest") pills.push(makeFilterPill("Sort: " + (sortLabels[selectedSort] || selectedSort), "sort"));
    activeFiltersBar.innerHTML = pills.join("");
    activeFiltersBar.querySelectorAll("[data-remove-filter]").forEach((btn) => {
      btn.addEventListener("click", (e) => { removeFilter((e.currentTarget as HTMLElement).getAttribute("data-remove-filter")!); });
    });
  }

  function makeFilterPill(label: string, filterKey: string): string {
    return `<button data-remove-filter="${filterKey}" class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full border border-primary/20 bg-primary/5 text-xs font-semibold text-primary hover:bg-primary/10 transition-colors">${label}<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>`;
  }

  function removeFilter(key: string) {
    switch (key) {
      case "condition": selectedCondition = "Any"; condChips.forEach((c, i) => { if (i === 0) { c.classList.add("bg-primary/10", "border-primary/30", "text-primary"); c.classList.remove("bg-muted", "border-border", "text-muted-foreground"); } else { c.classList.remove("bg-primary/10", "border-primary/30", "text-primary"); c.classList.add("bg-muted", "border-border", "text-muted-foreground"); } }); break;
      case "date": selectedDate = "any"; activateChip(dateChips, dateChips[0]); break;
      case "price": priceMin.value = ""; priceMax.value = ""; break;
      case "rating": selectedRating = "any"; ratingChips.forEach((c, i) => { if (i === 0) { c.classList.add("bg-primary/10", "border-primary/30", "text-primary"); c.classList.remove("bg-muted", "border-border", "text-muted-foreground"); } else { c.classList.remove("bg-primary/10", "border-primary/30", "text-primary"); c.classList.add("bg-muted", "border-border", "text-muted-foreground"); } }); break;
      case "listingType": currentListingType = ""; document.querySelectorAll<HTMLElement>(".listing-type-chip").forEach(c => deactivateTypeChip(c)); break;
      case "minViews": minViews.value = ""; break;
      case "hideOwn": hideOwnListings.checked = false; break;
      case "showOwn": showOnlyOwn.checked = false; break;
      case "sort": selectedSort = "newest"; activateChip(sortChips, sortChips[0]); break;
    }
    applyClientFilters();
  }

  clearAllFilters.addEventListener("click", () => {
    selectedSort = "newest"; activateChip(sortChips, sortChips[0]); priceMin.value = ""; priceMax.value = ""; selectedCondition = "Any";
    condChips.forEach((c, i) => { if (i === 0) { c.classList.add("bg-primary/10", "border-primary/30", "text-primary"); c.classList.remove("bg-muted", "border-border", "text-muted-foreground"); } else { c.classList.remove("bg-primary/10", "border-primary/30", "text-primary"); c.classList.add("bg-muted", "border-border", "text-muted-foreground"); } });
    selectedDate = "any"; activateChip(dateChips, dateChips[0]);
    selectedRating = "any"; ratingChips.forEach((c, i) => { if (i === 0) { c.classList.add("bg-primary/10", "border-primary/30", "text-primary"); c.classList.remove("bg-muted", "border-border", "text-muted-foreground"); } else { c.classList.remove("bg-primary/10", "border-primary/30", "text-primary"); c.classList.add("bg-muted", "border-border", "text-muted-foreground"); } });
    hideOwnListings.checked = false; showOnlyOwn.checked = false; minViews.value = "";
    currentListingType = "";
    document.querySelectorAll<HTMLElement>(".listing-type-chip").forEach(c => deactivateTypeChip(c));
    applyClientFilters();
  });

  applyFiltersBtn.addEventListener("click", () => { applyClientFilters(); });

  function getDateCutoff(value: string): Date | null {
    const now = new Date();
    switch (value) {
      case "today": return new Date(now.getFullYear(), now.getMonth(), now.getDate());
      case "3days": return new Date(now.getTime() - 3 * 24 * 60 * 60 * 1000);
      case "week": return new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
      case "month": return new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
      case "3months": return new Date(now.getTime() - 90 * 24 * 60 * 60 * 1000);
      default: return null;
    }
  }

  function renderCard(item: Listing): string {
    const gradient = CATEGORY_GRADIENTS[item.category] || "linear-gradient(135deg,#6b7280,#9ca3af)";
    const icon = CATEGORY_ICONS[item.category] || "\u{1F4E6}";
    const hasImage = item.images && item.images.length > 0;
    const sellerName = item.seller_name || "Seller";
    const imageHtml = hasImage ? `<img src="${item.images[0]}" alt="${item.title}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />` : `<span class="text-5xl">${icon}</span>`;
    const statusOverlay = item.status !== "available" ? `<div class="absolute inset-0 bg-black/40 flex items-center justify-center z-10"><span class="px-4 py-1.5 rounded-full font-extrabold uppercase tracking-widest text-sm text-white border-2 border-white">${item.status}</span></div>` : "";
    const saleBadge = item.on_sale && item.status === "available" && !item.is_auction ? `<span class="absolute top-3 left-3 z-10 inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-extrabold uppercase tracking-wide bg-orange-500 text-white shadow-lg">🏷️ On Sale</span>` : "";
    const freeBadge = item.price === 0 && item.status === "available" && !item.is_auction && !item.on_sale ? `<span class="absolute top-3 left-3 z-10 inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-extrabold uppercase tracking-wide bg-teal-500 text-white shadow-lg">🎁 Free</span>` : item.is_auction ? `<span class="absolute top-3 left-3 z-10 inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-extrabold uppercase tracking-wide bg-amber-500 text-white shadow-lg">⏱ Auction</span>` : "";
    const offersBadge = item.open_to_offers && item.status === "available" ? `<span class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide bg-violet-500/10 text-violet-600 border border-violet-200"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>Open to Offers</span>` : "";
    return `
      <a href="/item?id=${item.id}" class="listing-card group bg-card rounded-xl border border-border overflow-hidden no-underline text-inherit flex flex-col shadow-sm hover:-translate-y-2 hover:shadow-xl hover:border-primary/20 transition-all duration-300 fade-in-shimmer" data-category="${item.category}" data-price="${item.price}" data-id="${item.id}" ${item.is_auction && item.auction_end_time ? `data-auction-end="${item.auction_end_time}"` : ""}>
        <div class="h-55 relative flex items-center justify-center overflow-hidden" style="background: ${gradient}">
          ${imageHtml}
          <button type="button" class="save-btn card-fav-btn absolute top-3 right-3 w-10 h-10 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center text-muted-foreground hover:text-error z-10 border-0" aria-label="Save listing" data-id="${item.id}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg>
          </button>
          <span class="absolute bottom-2 right-2 z-10 inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-black/50 backdrop-blur-sm text-white text-[10px] font-semibold"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>${item.view_count ?? 0}</span>
          ${statusOverlay}${saleBadge}${freeBadge}
        </div>
        <div class="p-4 flex-1 flex flex-col gap-2">
          <div class="flex items-center justify-between">
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold text-primary bg-primary/10">${item.condition}</span>
            ${offersBadge}
          </div>
          <h3 class="text-base font-bold text-foreground leading-tight line-clamp-2">${item.title}</h3>
          ${item.is_auction && item.auction_end_time ? `<div class="flex items-center gap-1.5 text-xs font-semibold text-amber-600 auction-countdown" data-end="${item.auction_end_time}"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span></span></div>` : ""}
          <div class="flex items-center justify-between mt-auto pt-3 border-t border-border">
            <div class="flex flex-col leading-tight">
              ${item.on_sale && item.original_price && !item.is_auction ? `<span class="text-xs text-muted-foreground line-through">$${item.original_price}</span>` : ""}
              <span class="text-xl font-extrabold ${item.is_auction ? "text-amber-600 auction-bid-display" : item.on_sale ? "text-orange-500" : item.price === 0 ? "text-teal-600" : "text-primary"}" ${item.is_auction ? `data-listing-id="${item.id}" data-starting-bid="${item.starting_bid ?? 0}"` : ""}>${item.is_auction ? `$${item.starting_bid ?? 0}` : item.price === 0 ? "FREE" : "$" + item.price}</span>
            </div>
            <div class="seller-rating text-xs text-muted-foreground" data-seller-id="${item.user_id}"><span class="text-amber-400/50">★★★★★</span></div>
            <span class="text-sm font-semibold text-muted-foreground">${sellerName.split(" ")[0]}</span>
          </div>
        </div>
      </a>
    `;
  }

  function renderListings(listings: Listing[]) {
    loadingSkeleton.classList.add("hidden");
    if (listings.length === 0) { listingGrid.classList.add("hidden"); emptyState.classList.remove("hidden"); resultsCount.textContent = "0"; return; }
    emptyState.classList.add("hidden");
    listingGrid.classList.remove("hidden");
    listingGrid.innerHTML = listings.map(renderCard).join("");

    async function loadCardRatings() {
      const sellerIds = [...new Set(listings.map(l => l.user_id))];
      const uncachedIds = sellerIds.filter(id => !(id in sellerRatingsCache));
      await Promise.all(uncachedIds.map(async (sid) => { try { sellerRatingsCache[sid] = await fetchSellerRating(sid); } catch (_) { sellerRatingsCache[sid] = { average: 0, count: 0 }; } }));
      // Re-query after await so we update the live DOM, not stale references
      document.querySelectorAll<HTMLElement>(".seller-rating[data-seller-id]").forEach(el => {
        const rating = sellerRatingsCache[el.dataset.sellerId!];
        if (rating && rating.count > 0) { const full = Math.floor(rating.average); el.innerHTML = `<span class="text-amber-400">${"\u2605".repeat(full)}${"\u2606".repeat(5 - full)}</span> <span>${rating.average}</span>`; }
        else { el.innerHTML = `<span class="text-muted-foreground">No ratings</span>`; }
      });
    }
    loadCardRatings();

    async function loadAuctionBids() {
      const bidEls = document.querySelectorAll<HTMLElement>(".auction-bid-display[data-listing-id]");
      await Promise.all(Array.from(bidEls).map(async (el) => {
        const startingBid = parseFloat(el.dataset.startingBid || "0");
        try { const bids = await fetchBids(el.dataset.listingId!); el.textContent = bids.length > 0 ? `$${bids[0].amount.toFixed(2)}` : `$${startingBid.toFixed(2)}`; } catch (_) {}
      }));
    }
    loadAuctionBids();

    function updateAuctionCountdowns() {
      document.querySelectorAll<HTMLElement>(".auction-countdown[data-end]").forEach((el) => {
        const diff = new Date(el.dataset.end!).getTime() - Date.now();
        const span = el.querySelector("span")!;
        if (diff <= 0) { span.textContent = "Ended"; return; }
        const days = Math.floor(diff / 86400000), hrs = Math.floor((diff % 86400000) / 3600000), mins = Math.floor((diff % 3600000) / 60000), secs = Math.floor((diff % 60000) / 1000);
        span.textContent = days > 0 ? `${days}d ${hrs}h ${mins}m left` : `${hrs}h ${mins}m ${secs}s left`;
      });
    }
    updateAuctionCountdowns();
    setInterval(updateAuctionCountdowns, 1000);

    resultsCount.textContent = listings.length.toString();
    const observer = new IntersectionObserver((entries) => { entries.forEach((entry) => { if (entry.isIntersecting) { entry.target.classList.add("fade-in-visible"); observer.unobserve(entry.target); } }); }, { threshold: 0.1, rootMargin: "0px 0px -50px 0px" });
    listingGrid.querySelectorAll(".listing-card").forEach((card) => observer.observe(card));
  }

  async function applyClientFilters() {
    const min = parseFloat(priceMin.value || "0");
    const max = parseFloat(priceMax.value || "Infinity") || Infinity;
    const params = new URLSearchParams(window.location.search);
    const query = (params.get("q") || params.get("search"))?.toLowerCase() || "";
    const savedOnly = params.get("saved") === "true";
    const { data: { user } } = await supabase.auth.getUser();
    let savedIds: Set<String> = new Set();
    if (user) {
      const { data } = await supabase.from("saved_listings").select("listing_id").eq("user_id", user.id);
      savedIds = new Set((data ?? []).map((row: any) => row.listing_id.toString()));
    }

    let filtered = allListings;

    if (currentCat !== "All") filtered = filtered.filter((l) => l.category === currentCat);
    if (currentListingType === "Auctions") filtered = filtered.filter((l) => l.is_auction);
    else if (currentListingType === "On Sale") filtered = filtered.filter((l) => l.on_sale && !l.is_auction);
    else if (currentListingType === "Free") filtered = filtered.filter((l) => l.price === 0 && !l.is_auction);

    if (min > 0) filtered = filtered.filter((l) => l.price >= min);
    if (max < Infinity) filtered = filtered.filter((l) => l.price <= max);
    if (query) filtered = filtered.filter((l) => l.title.toLowerCase().includes(query));
    if (savedOnly) filtered = filtered.filter((l) => savedIds.has(l.id.toString()));
    if (selectedCondition !== "Any") filtered = filtered.filter((l) => l.condition === selectedCondition);

    const dateCutoff = getDateCutoff(selectedDate);
    if (dateCutoff) filtered = filtered.filter((l) => new Date(l.created_at) >= dateCutoff);

    const minViewsVal = parseInt(minViews.value || "0");
    if (minViewsVal > 0) filtered = filtered.filter((l) => (l.view_count ?? 0) >= minViewsVal);

    if (user) {
      if (hideOwnListings.checked) filtered = filtered.filter((l) => l.user_id !== user.id);
      if (showOnlyOwn.checked) filtered = filtered.filter((l) => l.user_id === user.id);
    }

    if (selectedRating !== "any") {
      const minRating = parseFloat(selectedRating);
      const sellerIds = [...new Set(filtered.map((l) => l.user_id))];
      const uncachedIds = sellerIds.filter((id) => !(id in sellerRatingsCache));
      if (uncachedIds.length > 0) await Promise.all(uncachedIds.map(async (sid) => { try { sellerRatingsCache[sid] = await fetchSellerRating(sid); } catch (_) { sellerRatingsCache[sid] = { average: 0, count: 0 }; } }));
      filtered = filtered.filter((l) => { const r = sellerRatingsCache[l.user_id]; return r && r.count > 0 && r.average >= minRating; });
    }

    if (selectedSort === "price_asc") filtered = [...filtered].sort((a, b) => a.price - b.price);
    else if (selectedSort === "price_desc") filtered = [...filtered].sort((a, b) => b.price - a.price);
    else if (selectedSort === "rating_desc") filtered = [...filtered].sort((a, b) => (sellerRatingsCache[b.user_id]?.average || 0) - (sellerRatingsCache[a.user_id]?.average || 0));
    else if (selectedSort === "views_desc") filtered = [...filtered].sort((a, b) => (b.view_count ?? 0) - (a.view_count ?? 0));

    renderListings(filtered);
    updateFilterBadge();
    renderActiveFilterPills();
  }

  function renderTrending() {
    const trendingSection = document.getElementById("trendingSection")!;
    
    const savedOnly = new URLSearchParams(window.location.search).get("saved") === "true";
    if (savedOnly) {
      trendingSection.classList.add("hidden");
      return;
    }
    
    const trendingGrid = document.getElementById("trendingGrid")!;
    const hasDailyData = allListings.some((l) => (l.daily_views ?? 0) > 0);
    const top = allListings
      .filter((l) => l.status === "available" && (hasDailyData ? (l.daily_views ?? 0) > 0 : (l.view_count ?? 0) > 0))
      .sort((a, b) => hasDailyData ? (b.daily_views ?? 0) - (a.daily_views ?? 0) : (b.view_count ?? 0) - (a.view_count ?? 0))
      .slice(0, 4);
    if (top.length === 0) { trendingSection.classList.add("hidden"); return; }
    trendingSection.classList.remove("hidden");
    trendingGrid.innerHTML = top.map((item) => renderCard(item)).join("");
    trendingGrid.querySelectorAll<HTMLElement>(".listing-card").forEach((card) => card.classList.add("fade-in-visible"));
    const trendingGrid2 = document.getElementById("trendingGrid")!;
    const chevron = document.getElementById("trendingChevron")!;
    if (localStorage.getItem("trendingHidden") === "1") {
      trendingGrid2.classList.add("hidden");
      chevron.style.transform = "rotate(180deg)";
    }
    document.getElementById("hideTrendingBtn")!.addEventListener("click", () => {
      const isHidden = trendingGrid2.classList.toggle("hidden");
      chevron.style.transform = isHidden ? "rotate(180deg)" : "rotate(0deg)";
      localStorage.setItem("trendingHidden", isHidden ? "1" : "0");
    });

    trendingGrid.querySelectorAll<HTMLElement>(".seller-rating[data-seller-id]").forEach(async (el) => {
      const sid = el.dataset.sellerId!;
      if (!(sid in sellerRatingsCache)) { try { sellerRatingsCache[sid] = await fetchSellerRating(sid); } catch (_) { sellerRatingsCache[sid] = { average: 0, count: 0 }; } }
      const rating = sellerRatingsCache[sid];
      if (rating && rating.count > 0) { const full = Math.floor(rating.average); el.innerHTML = `<span class="text-amber-400">${"★".repeat(full)}${"☆".repeat(5 - full)}</span> <span>${rating.average}</span>`; }
      else { el.innerHTML = `<span class="text-muted-foreground">No ratings</span>`; }
    });
  }

  async function loadListings() {
    try { allListings = await fetchListings(); renderTrending(); applyClientFilters(); }
    catch (err) {
      console.error("Failed to load listings:", err);
      loadingSkeleton.classList.add("hidden"); emptyState.classList.remove("hidden");
      const h3 = emptyState.querySelector("h3"); const p = emptyState.querySelector("p");
      if (h3) h3.textContent = "Failed to load listings"; if (p) p.textContent = "Please try refreshing the page.";
    }
  }

  const typeChipActive: Record<string, string[]> = {
    Free: ["bg-teal-500", "border-teal-500", "text-white"],
    Auctions: ["bg-amber-500", "border-amber-500", "text-white"],
    "On Sale": ["bg-orange-500", "border-orange-500", "text-white"],
  };
  const typeChipBase: Record<string, string[]> = {
    Free: ["bg-teal-500/10", "border-teal-300", "text-teal-700"],
    Auctions: ["bg-amber-500/10", "border-amber-300", "text-amber-700"],
    "On Sale": ["bg-orange-500/10", "border-orange-300", "text-orange-700"],
  };

  function deactivateTypeChip(chip: HTMLElement) {
    const type = chip.dataset.type!;
    chip.classList.remove(...(typeChipActive[type] || []), "ring-2", "ring-offset-1");
    chip.classList.add(...(typeChipBase[type] || []));
  }

  document.querySelectorAll<HTMLElement>(".listing-type-chip").forEach((chip) => {
    chip.addEventListener("click", () => {
      const type = chip.dataset.type!;
      if (currentListingType === type) {
        currentListingType = "";
        deactivateTypeChip(chip);
      } else {
        document.querySelectorAll<HTMLElement>(".listing-type-chip").forEach(c => deactivateTypeChip(c));
        currentListingType = type;
        chip.classList.remove(...(typeChipBase[type] || []));
        chip.classList.add(...(typeChipActive[type] || []), "ring-2", "ring-offset-1");
      }
      applyClientFilters();
    });
  });

  catChips.forEach((chip) => {
    chip.addEventListener("click", () => {
      catChips.forEach((c) => { c.classList.remove("active", "bg-primary", "border-primary", "text-primary-foreground", "shadow-sm"); c.classList.add("bg-card", "border-border", "text-muted-foreground"); });
      chip.classList.remove("bg-card", "border-border", "text-muted-foreground");
      chip.classList.add("active", "bg-primary", "border-primary", "text-primary-foreground", "shadow-sm");
      currentCat = chip.getAttribute("data-cat") || "All";
      applyClientFilters();
    });
  });

  window.addEventListener("saved-changed", applyClientFilters);
  loadListings();
</script>

<style is:global>
  .fade-in-shimmer { opacity: 0; transform: translateY(20px); transition: opacity 0.6s cubic-bezier(0.23, 1, 0.32, 1), transform 0.6s cubic-bezier(0.23, 1, 0.32, 1); }
  .fade-in-visible { opacity: 1; transform: translateY(0); }
</style>