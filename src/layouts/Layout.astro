---
import "@/styles/starwind.css";
interface Props {
  title?: string;
  showNav?: boolean;
  showFooter?: boolean;
  authLayout?: boolean;
}
const {
  title = "FSC Marketplace",
  showNav = true,
  showFooter = true,
  authLayout = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title} | FSC Student Marketplace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      html, body {
        font-family: "Plus Jakarta Sans", system-ui, -apple-system, sans-serif;
      }
    </style>
  </head>
  <body>
    {
      authLayout ? (
        <nav class="bg-card h-20 flex items-center justify-center border-b border-border/50">
          <a href="/marketplace" class="flex items-center gap-3 no-underline text-foreground hover:scale-[1.02] transition-transform shrink-0">
            <div class="w-10.5 h-10.5 bg-primary rounded-xl flex items-center justify-center font-extrabold text-white text-sm shadow-md">FSC</div>
            <div class="leading-tight">
              <span class="text-[0.95rem] font-bold block tracking-tight">Farmingdale State College</span>
              <span class="text-[0.65rem] font-semibold text-muted-foreground uppercase tracking-widest block">Student Marketplace</span>
            </div>
          </a>
        </nav>
      ) : showNav ? (
        <nav class="bg-card/80 backdrop-blur-xl h-18 sticky top-0 z-200 border-b border-border">
          <div class="max-w-300 mx-auto h-full px-8 flex items-center gap-6">
            <button class="hidden max-md:block bg-transparent border-0 text-muted-foreground cursor-pointer p-2" id="menuToggle">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <>
                  <line x1="3" y1="12" x2="21" y2="12" />
                  <line x1="3" y1="6" x2="21" y2="6" />
                  <line x1="3" y1="18" x2="21" y2="18" />
                </>
              </svg>
            </button>
            <a href="/marketplace" class="flex items-center gap-3 no-underline text-foreground hover:scale-[1.02] transition-transform shrink-0">
              <div class="w-10.5 h-10.5 bg-primary rounded-xl flex items-center justify-center font-extrabold text-white text-sm shadow-md">FSC</div>
              <div class="leading-tight">
                <span class="text-[0.95rem] font-bold block tracking-tight">Farmingdale State College</span>
                <span class="text-[0.65rem] font-semibold text-muted-foreground uppercase tracking-widest block">Student Marketplace</span>
              </div>
            </a>
            <div class="flex-1 max-w-100 relative max-md:hidden">
              <svg class="nav-search-icon absolute left-4 top-1/2 -translate-y-1/2 text-muted-foreground" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <>
                  <circle cx="11" cy="11" r="8" />
                  <path d="m21 21-4.35-4.35" />
                </>
              </svg>
              <input
                type="text"
                placeholder="Search textbooks, electronics..."
                class="nav-search-input w-full py-2.5 pl-11 pr-4 rounded-full border-[1.5px] border-border bg-card text-foreground text-sm outline-none transition-all focus:border-primary focus:ring-4 focus:ring-primary/10"
              />
            </div>
            <div class="flex items-center gap-3 ml-auto max-md:fixed max-md:top-18 max-md:left-0 max-md:right-0 max-md:bg-card max-md:flex-col max-md:p-8 max-md:border-b max-md:border-border max-md:-translate-y-full max-md:opacity-0 max-md:pointer-events-none max-md:transition-all max-md:duration-300 max-md:z-199" id="navActions">
              <!-- Shown when logged IN -->
              <div id="navLoggedIn" style="display:none;align-items:center;gap:0.75rem;">
                <a href="/post" class="bg-primary text-white font-bold text-sm py-2.5 px-5 rounded-full no-underline transition-all shadow-sm hover:bg-primary-accent hover:-translate-y-px hover:shadow-md max-md:w-full max-md:text-center max-md:py-4">
                  List an Item
                </a>
                <a
                  href="/marketplace?saved=true"
                  class="nav-icon-btn w-10 h-10 rounded-full border-[1.5px] border-border bg-card text-muted-foreground flex items-center justify-center no-underline transition-all relative hover:border-primary hover:text-primary hover:bg-primary/5"
                  title="Saved Items"
                >
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.84-8.84 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                  </svg>
                  <span class="nav-icon-badge absolute -top-0.5 -right-0.5 bg-amber-400 text-foreground text-[0.65rem] font-extrabold min-w-4.5 h-4.5 px-1 rounded-full flex items-center justify-center border-2 border-card">0</span>
                </a>
                <a href="/messages" class="nav-icon-btn w-10 h-10 rounded-full border-[1.5px] border-border bg-card text-muted-foreground flex items-center justify-center no-underline transition-all relative hover:border-primary hover:text-primary hover:bg-primary/5" title="Messages">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                  </svg>
                  <span class="absolute -top-0.5 -right-0.5 bg-amber-400 text-foreground text-[0.65rem] font-extrabold min-w-4.5 h-4.5 px-1 rounded-full flex items-center justify-center border-2 border-card">3</span>
                </a>
                <a href="/profile" class="nav-icon-btn w-10 h-10 rounded-full border-[1.5px] border-border bg-card text-muted-foreground flex items-center justify-center no-underline transition-all relative hover:border-primary hover:text-primary hover:bg-primary/5" title="Profile">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <>
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                      <circle cx="12" cy="7" r="4" />
                    </>
                  </svg>
                </a>
                <button
                    data-signout
                    class="nav-icon-btn w-10 h-10 rounded-full border-[1.5px] border-border bg-card text-muted-foreground flex items-center justify-center no-underline transition-all relative hover:border-primary hover:text-primary hover:bg-primary/5 cursor-pointer"
                    title="Logout"
                >
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                  </svg>
                </button>
              </div>
              <!-- Shown when logged OUT -->
              <div id="navLoggedOut" style="display:flex;align-items:center;gap:0.75rem;">
                <a href="/login" class="inline-flex items-center justify-center bg-card text-primary font-semibold text-sm py-2 px-5 rounded-xl border-[1.5px] border-primary no-underline transition-all hover:bg-primary/5">Log In</a>
                <a href="/signup" class="bg-primary text-white font-bold text-sm py-2.5 px-5 rounded-full no-underline transition-all shadow-sm hover:bg-primary-accent hover:-translate-y-px hover:shadow-md">Sign Up</a>
              </div>
            </div>
          </div>
        </nav>
      ) : null
    }

    <main class="min-h-[calc(100vh-72px)]">
      <slot />
    </main>

    {
      showFooter && (
        <footer class="bg-card text-foreground pt-16 pb-8 px-6 mt-24 border-t border-border">
          <div class="max-w-300 mx-auto grid grid-cols-[2fr_1fr_1fr_1fr] gap-12 max-md:grid-cols-1 max-md:gap-10 max-md:text-center">
            <div>
              <div class="flex items-center gap-4 mb-5 max-md:justify-center">
                <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center font-extrabold text-white text-base">FSC</div>
                <div>
                  <div class="font-bold text-[0.92rem]">Farmingdale State College</div>
                  <div class="text-xs text-muted-foreground">Student Marketplace</div>
                </div>
              </div>
              <p class="text-sm text-muted-foreground leading-relaxed max-w-65">
                A secure, campus-exclusive platform for FSC students to buy,
                sell, and exchange items.
              </p>
            </div>
            <div>
              <p class="text-sm font-bold text-foreground mb-6 uppercase tracking-widest">Community</p>
              <ul class="list-none flex flex-col gap-3">
                <li><a href="#" class="text-sm text-muted-foreground no-underline transition-colors hover:text-primary">FAQ</a></li>
                <li><a href="#" class="text-sm text-muted-foreground no-underline transition-colors hover:text-primary">Contact Forms</a></li>
                <li><a href="#" class="text-sm text-muted-foreground no-underline transition-colors hover:text-primary">Safety Tips</a></li>
                <li><a href="#" class="text-sm text-muted-foreground no-underline transition-colors hover:text-primary">About Us</a></li>
              </ul>
            </div>
            <div>
              <p class="text-sm font-bold text-foreground mb-6 uppercase tracking-widest">Sitemap</p>
              <ul class="list-none flex flex-col gap-3">
                <li><a href="/marketplace" class="text-sm text-muted-foreground no-underline transition-colors hover:text-primary">Marketplace</a></li>
                <li><a href="/profile" class="text-sm text-muted-foreground no-underline transition-colors hover:text-primary">My Profile</a></li>
                <li><a href="#" class="text-sm text-muted-foreground no-underline transition-colors hover:text-primary">Privacy Policy</a></li>
                <li><a href="#" class="text-sm text-muted-foreground no-underline transition-colors hover:text-primary">Terms of Service</a></li>
              </ul>
            </div>
          </div>
          <hr class="max-w-300 mx-auto mt-12 mb-8 border-0 border-t border-border/50" />
          <p class="max-w-300 mx-auto text-sm text-muted-foreground text-center">
            &copy; 2026 Farmingdale State College Student Marketplace. All rights
            reserved.
          </p>
        </footer>
      )
    }

    <script>
      import { supabase } from '../lib/supabase';

      // Session-aware nav
      function setAuthNav(loggedIn: boolean) {
        const navLoggedIn = document.getElementById('navLoggedIn');
        const navLoggedOut = document.getElementById('navLoggedOut');
        if (navLoggedIn) navLoggedIn.style.display = loggedIn ? 'flex' : 'none';
        if (navLoggedOut) navLoggedOut.style.display = loggedIn ? 'none' : 'flex';
      }

      supabase.auth.getSession().then(({ data: { session } }) => {
        setAuthNav(!!session);
      });

      supabase.auth.onAuthStateChange((_event, session) => {
        setAuthNav(!!session);
      });

      // Mobile menu toggle
      document.getElementById("menuToggle")?.addEventListener("click", () => {
        const navActions = document.getElementById("navActions");
        if (navActions) {
          const isOpen = !navActions.classList.contains("max-md:-translate-y-full");
          if (isOpen) {
            navActions.classList.add("max-md:-translate-y-full", "max-md:opacity-0", "max-md:pointer-events-none");
          } else {
            navActions.classList.remove("max-md:-translate-y-full", "max-md:opacity-0", "max-md:pointer-events-none");
          }
        }
      });

      (function () {
        const STORAGE_KEY = "fsc_marketplace_saved";

        function getSavedIds(): string[] {
          try {
            return JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]").map(
              (id: any) => id.toString(),
            );
          } catch (e) {
            return [];
          }
        }

        function updateUI() {
          const ids = getSavedIds();
          const idSet = new Set(ids);

          // Update all hearts
          document.querySelectorAll(".save-btn").forEach((btn) => {
            const id = btn.getAttribute("data-id");
            const heartPath = btn.querySelector("path");
            if (id && idSet.has(id.toString())) {
              btn.classList.add("active");
              if (heartPath) heartPath.setAttribute("fill", "currentColor");
            } else {
              btn.classList.remove("active");
              if (heartPath) heartPath.setAttribute("fill", "none");
            }
          });

          // Update all badges
          document.querySelectorAll(".nav-icon-badge").forEach((badge) => {
            badge.textContent = ids.length.toString();
          });
        }

        // Global Click Handler for Saves
        document.addEventListener("click", (e) => {
          const btn = (e.target as HTMLElement).closest(".save-btn");
          if (btn) {
            e.preventDefault();
            e.stopPropagation();
            const id = btn.getAttribute("data-id");
            if (!id) return;

            let ids = getSavedIds();
            const idStr = id.toString();
            const index = ids.indexOf(idStr);

            if (index > -1) {
              ids.splice(index, 1);
            } else {
              ids.push(idStr);
            }

            localStorage.setItem(STORAGE_KEY, JSON.stringify(ids));
            updateUI();

            // Notify marketplace page
            window.dispatchEvent(
              new CustomEvent("saved-changed", { detail: { ids } }),
            );
          }
        });

        // Global Search
        function executeSearch(query: string) {
          if (!query.trim()) return;
          window.location.href = `/marketplace?q=${encodeURIComponent(query.trim())}`;
        }

        document.addEventListener("keyup", (e) => {
          const input = e.target as HTMLElement;
          if (
            input.classList.contains("nav-search-input") &&
            e.key === "Enter"
          ) {
            executeSearch((input as HTMLInputElement).value);
          }
        });

        // Handle Search Icon Click
        document.addEventListener("click", (e) => {
          if ((e.target as HTMLElement).closest(".nav-search-icon")) {
            const input = document.querySelector(
              ".nav-search-input",
            ) as HTMLInputElement;
            if (input) executeSearch(input.value);
          }
        });

        // Initial sync
        updateUI();

        // Polling sync (fallback for cross-tab or complex race conditions)
        setInterval(updateUI, 2000);
      })();

      // Close menu when clicking outside
      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        const menuToggle = document.getElementById("menuToggle");
        const navActions = document.getElementById("navActions");
        if (!menuToggle?.contains(target) && !navActions?.contains(target)) {
          navActions?.classList.add("max-md:-translate-y-full", "max-md:opacity-0", "max-md:pointer-events-none");
        }
      });
    </script>

    <script>
      import { supabase } from "../lib/supabase";

      const PROTECTED_PATHS = ["/profile", "/post", "/messages"];
      const AUTH_PATHS = ["/login", "/signup"];
      const currentPath = window.location.pathname;

      async function initAuth() {
        const {
          data: { session },
        } = await supabase.auth.getSession();

        // Guard protected routes — redirect to login if not authenticated
        if (
          !session &&
          PROTECTED_PATHS.some((p) => currentPath.startsWith(p))
        ) {
          window.location.href = "/login";
          return;
        }

        // If logged in and on auth pages, redirect to marketplace
        if (session && AUTH_PATHS.some((p) => currentPath.startsWith(p))) {
          window.location.href = "/marketplace";
          return;
        }

        // Update nav UI if a session exists
        if (session?.user) {
          const meta = session.user.user_metadata;
          const fullName: string = meta?.full_name || session.user.email || "";
          const initials =
            fullName
              .split(" ")
              .map((w: string) => w[0])
              .join("")
              .toUpperCase()
              .slice(0, 2) || "U";

          // Replace the profile SVG icon with initials
          const profileBtn = document.querySelector(
            'a[href="/profile"].nav-icon-btn',
          );
          if (profileBtn) {
            profileBtn.innerHTML = `<span style="font-weight:700;font-size:0.75rem;color:var(--primary);">${initials}</span>`;
          }
        }
      }

      // Sign-out handler — attach to any element with data-signout attribute
      document.addEventListener("click", async (e) => {
        const btn = (e.target as HTMLElement).closest("[data-signout]");
        if (btn) {
          e.preventDefault();
          await supabase.auth.signOut();
          window.location.href = "/login";
        }
      });

      initAuth();
    </script>
  </body>
</html>
